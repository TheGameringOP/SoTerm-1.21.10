      "com.github.gameringop.integration.SoTermModMenuIntegration"
    ],
    "client": [
      {
        "adapter": "kotlin"
        "value": "com.github.gameringop.SoTerm",
      }
    ]
  },
  "mixins": [
    "soterm.mixins.json"
  ],
  "depends": {
    "fabricloader": ">=0.17.3",
    "minecraft": "~1.21.10",
